{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyCreateOrUpdateRoleWithoutBoundary",
      "Effect": "Deny",
      "Action": [
        "iam:CreateRole",
        "iam:PutRolePermissionsBoundary",
        "iam:DeleteRolePermissionsBoundary"
      ],
      "Resource": "arn:aws:iam::*:role/*",
      "Condition": {
        "StringNotEquals": {
          "iam:PermissionsBoundary": "arn:aws:iam::123456789012:policy/hesp-permission-boundary"
        }
      }
    }
  ]
}
